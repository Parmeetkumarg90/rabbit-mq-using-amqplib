{
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/common": "^11.1.20",
    "@nestjs/core": "^11.1.20",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/testing": "^11.1.21",
    "@types/node": "^25.7.0",
    "amqplib": "^2.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "supertest": "^7.2.2",
    "typeorm": "^0.3.29",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript-eslint": "^8.59.3"
  },
  "name": "producer",
  "version": "1.0.0",
  "description": "<p align=\"center\">   <a href=\"http://nestjs.com/\" target=\"blank\"><img src=\"https://nestjs.com/img/logo-small.svg\" width=\"120\" alt=\"Nest Logo\" /></a> </p>",
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:generate": "npx typeorm migration:generate -d dist/infrastructure/database/database-datasource.js src/infrastructure/database/migrations/InitMigration",
    "migration:run": "npx typeorm migration:run -d dist/infrastructure/database/database-datasource.js",
    "migration:revert": "npx typeorm migration:revert -d dist/infrastructure/database/database-datasource.js",
    "seed": "ts-node -r tsconfig-paths/register src/infrastructure/database/seeder.ts",
    "seed:prod": "node dist/infrastructure/database/seeder.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@nestjs/typeorm": "^11.0.1",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
